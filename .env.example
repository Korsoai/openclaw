# OpenClaw .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.openclaw/.env` (for launchd/systemd daemons).
#    For Railway deployments, set variables directly in the Railway dashboard (not in a file).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.openclaw/.env, then openclaw.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in openclaw.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Railway deployment (only needed when deploying to Railway)
# -----------------------------------------------------------------------------
# Required: protects the /setup onboarding wizard.
# SETUP_PASSWORD=change-me-to-a-strong-password

# Optional: wipe memories/workspace while preserving config on next restart.
# Remove after triggering to prevent wiping on every restart.
# OPENCLAW_RESET_MEMORIES=1

# Optional: full factory reset (wipes all state including config) on next restart.
# Remove after triggering to prevent wiping on every restart.
# OPENCLAW_FACTORY_RESET=1

# Railway auto-sets these; override only if needed.
# PORT=8080
# OPENCLAW_STATE_DIR=/data/.openclaw
# OPENCLAW_WORKSPACE_DIR=/data/workspace

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
# OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# OPENCLAW_HOME=~

# Optional: import missing keys from your login shell profile.
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...

# Multiple keys (comma-separated or numbered) for key rotation
# OPENAI_API_KEYS=sk-1,sk-2
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEYS=key-1,key-2
# GEMINI_API_KEY_1=...

# Alternative env names accepted by the code
# GOOGLE_API_KEY=...          # alias for Gemini
# ZAI_API_KEY=...             # ZAI / Z.AI
# Z_AI_API_KEY=...            # alias for ZAI_API_KEY
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# MINIMAX_CODE_PLAN_KEY=...   # Minimax code-plan endpoint key
# XIAOMI_API_KEY=...          # Xiaomi AI
# SYNTHETIC_API_KEY=...

# Live-test overrides (used by pnpm test:live only)
# OPENCLAW_LIVE_OPENAI_KEY=sk-...
# OPENCLAW_LIVE_ANTHROPIC_KEY=sk-ant-...
# OPENCLAW_LIVE_GEMINI_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------

# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...

# Discord
# DISCORD_BOT_TOKEN=...

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Mattermost
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com

# LINE
# LINE_CHANNEL_ACCESS_TOKEN=...

# Zalo
# ZALO_BOT_TOKEN=...

# Microsoft Teams
# MSTEAMS_APP_ID=...
# MSTEAMS_APP_PASSWORD=...
# MSTEAMS_TENANT_ID=...

# Nextcloud Talk
# NEXTCLOUD_TALK_BOT_SECRET=...

# IRC
# IRC_HOST=irc.libera.chat
# IRC_PORT=6697
# IRC_NICK=my-bot
# IRC_USERNAME=my-bot
# IRC_REALNAME=OpenClaw Bot
# IRC_PASSWORD=...
# IRC_TLS=true
# IRC_CHANNELS=#general,#mychannel
# IRC_NICKSERV_PASSWORD=...
# IRC_NICKSERV_REGISTER_EMAIL=...

# Synology Chat
# SYNOLOGY_CHAT_TOKEN=...
# SYNOLOGY_CHAT_INCOMING_URL=https://nas.example.com/webapi/...
# SYNOLOGY_NAS_HOST=localhost
# SYNOLOGY_ALLOWED_USER_IDS=1,2,3
# SYNOLOGY_RATE_LIMIT=10

# Twitch
# OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# Nostr (uses config file, no dedicated env token)

# -----------------------------------------------------------------------------
# Voice calls (voice-call extension — Twilio, Telnyx, or Plivo)
# -----------------------------------------------------------------------------

# Twilio
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...

# Telnyx
# TELNYX_API_KEY=...
# TELNYX_CONNECTION_ID=...
# TELNYX_PUBLIC_KEY=...

# Plivo
# PLIVO_AUTH_ID=MA...
# PLIVO_AUTH_TOKEN=...

# ngrok tunnel (for exposing local webhook to the internet during voice calls)
# NGROK_AUTHTOKEN=...
# NGROK_DOMAIN=your-static-domain.ngrok-free.app

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ElevenLabs text-to-speech
# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ELEVENLABS_API_KEY

# Deepgram speech-to-text
# DEEPGRAM_API_KEY=...

# -----------------------------------------------------------------------------
# Telemetry / OpenTelemetry (diagnostics-otel extension, optional)
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME=openclaw

# -----------------------------------------------------------------------------
# Advanced / debug flags (optional, rarely needed)
# -----------------------------------------------------------------------------
# Custom bot display name (used by some channels, e.g. Synology Chat)
# OPENCLAW_BOT_NAME=OpenClaw

# Override mDNS/Bonjour hostname advertised on LAN
# OPENCLAW_MDNS_HOSTNAME=my-gateway.local

# Disable mDNS/Bonjour advertisement
# OPENCLAW_DISABLE_BONJOUR=1

# Image processing backend (auto-detected; override if needed)
# OPENCLAW_IMAGE_BACKEND=sharp   # or: sips (macOS only)

# Allow project-local bin directory on PATH (security trade-off)
# OPENCLAW_ALLOW_PROJECT_LOCAL_BIN=1
